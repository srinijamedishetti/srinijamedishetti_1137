def check_even_odd(number):
    """Checks if a number is even or odd and returns a descriptive string."""
    if number % 2 == 0:
        return f"{number} is an even number."
    else:
        return f"{number} is an odd number."

test_num1 = 42
test_num2 = 19

print(check_even_odd(test_num1))
print(check_even_odd(test_num2))