candidate = 29
is_prime = True

if candidate <= 1:
    is_prime = False
else:
    for i in range(2, int(candidate**0.5) + 1):
        if candidate % i == 0:
            is_prime = False
            break

if is_prime:
    print(f"The number {candidate} is a prime number.")
else:
    print(f"The number {candidate} is not a prime number.")