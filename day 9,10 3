principal_amount = float(input("Enter the initial principal amount: "))
annual_interest_rate = float(input("Enter the annual interest rate (as a percentage): "))
investment_duration_years = float(input("Enter the time duration in years: "))

calculated_simple_interest = (principal_amount * annual_interest_rate * investment_duration_years) / 100

print(f"\nThe calculated Simple Interest for this duration is: {calculated_simple_interest}")